<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  Parallel Suite — maximum concurrency for CI speed.
  Thread count is overridable via -Dthreads JVM property.

  ThreadLocal<ApiClient> in BaseTest ensures each thread has its own
  isolated HTTP client — no shared state, no race conditions.
-->
<suite name="API Regression — Parallel"
       parallel="classes"
       thread-count="5"
       verbose="2"
       data-provider-thread-count="5">

    <listeners>
        <listener class-name="com.vinoth.api.utils.RetryAnalyzer$RetryListener"/>
    </listeners>

    <test name="User Tests — Parallel">
        <classes>
            <class name="com.vinoth.api.tests.users.GetUserTests"/>
            <class name="com.vinoth.api.tests.users.CreateUserTests"/>
            <class name="com.vinoth.api.tests.users.DeleteUserTests"/>
        </classes>
    </test>

    <test name="Post Tests — Parallel">
        <classes>
            <class name="com.vinoth.api.tests.posts.PostCrudTests"/>
        </classes>
    </test>

</suite>