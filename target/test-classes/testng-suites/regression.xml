<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  Regression Suite — full coverage, sequential within test groups.
  Runs on schedule or manual trigger.
-->
<suite name="API Regression Suite"
       parallel="classes"
       thread-count="5"
       verbose="1">

    <listeners>
        <listener class-name="com.vinoth.api.utils.RetryAnalyzer$RetryListener"/>
    </listeners>

    <test name="User API Tests">
        <classes>
            <class name="com.vinoth.api.tests.users.GetUserTests"/>
            <class name="com.vinoth.api.tests.users.CreateUserTests"/>
            <class name="com.vinoth.api.tests.users.DeleteUserTests"/>
        </classes>
    </test>

    <test name="Post API Tests">
        <classes>
            <class name="com.vinoth.api.tests.posts.PostCrudTests"/>
        </classes>
    </test>

</suite>