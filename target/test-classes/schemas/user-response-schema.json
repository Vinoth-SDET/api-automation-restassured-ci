{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "user-response-schema",
  "title": "User Response",
  "description": "JSON Schema contract for GET /users/{id} response",
  "type": "object",
  "required": [
    "id",
    "name",
    "username",
    "email"
  ],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "integer",
      "minimum": 1,
      "description": "Unique user identifier"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Full display name"
    },
    "username": {
      "type": "string",
      "minLength": 1
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "User email address — must be valid email format"
    },
    "phone": {
      "type": "string"
    },
    "website": {
      "type": "string"
    },
    "address": {
      "type": "object",
      "properties": {
        "street": {
          "type": "string"
        },
        "suite": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "zipcode": {
          "type": "string"
        }
      }
    },
    "company": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "catchPhrase": {
          "type": "string"
        },
        "bs": {
          "type": "string"
        }
      }
    }
  }
}