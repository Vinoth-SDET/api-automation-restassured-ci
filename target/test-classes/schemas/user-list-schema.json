{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "User List Response",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["id", "name", "email"],
    "properties": {
      "id":       { "type": "integer" },
      "name":     { "type": "string"  },
      "username": { "type": "string"  },
      "email":    { "type": "string"  }
    }
  }
}