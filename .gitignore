# ── Build output ──────────────────────────────────────────────────────────────
  target/
  *.class
  *.jar
  *.war

  # ── Maven ─────────────────────────────────────────────────────────────────────
    .mvn/wrapper/maven-wrapper.jar
  !**/src/main/**/target/
  !**/src/test/**/target/

  # ── Allure reports ────────────────────────────────────────────────────────────
    allure-results/
    allure-report/
    allure-history/

  # ── Logs ──────────────────────────────────────────────────────────────────────
  *.log
  *.log.gz

  # ── Docker ────────────────────────────────────────────────────────────────────
    output/

  # ── IDE ───────────────────────────────────────────────────────────────────────
    .idea/
  *.iml
  *.iws
    .classpath
    .project
    .settings/
  *.swp
  *.swo
    .vscode/

  # ── OS ────────────────────────────────────────────────────────────────────────
    .DS_Store
    Thumbs.db

  # ── Secrets (NEVER commit these) ─────────────────────────────────────────────
  *.env
    .env.*
    secrets.properties