{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Post List Response",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["id", "userId", "title", "body"],
    "properties": {
      "id":     { "type": "integer" },
      "userId": { "type": "integer" },
      "title":  { "type": "string"  },
      "body":   { "type": "string"  }
    }
  }
}