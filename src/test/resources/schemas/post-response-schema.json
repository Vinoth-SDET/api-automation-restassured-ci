{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Post Response Schema",
  "description": "Validates a single post object returned by GET /posts/{id}",
  "type": "object",
  "required": [
    "id",
    "userId",
    "title",
    "body"
  ],
  "properties": {
    "id": {
      "type": "integer",
      "minimum": 1
    },
    "userId": {
      "type": "integer",
      "minimum": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "body": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}