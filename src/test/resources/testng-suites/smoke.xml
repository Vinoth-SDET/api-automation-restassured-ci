<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  Smoke Suite — fast sanity check (~4 tests, under 60 seconds).
  thread-count="1" keeps smoke sequential to avoid parallel retry confusion.
-->
<suite name="API Smoke Suite"
       parallel="false"
       verbose="1">

    <listeners>
        <listener class-name="com.vinoth.api.utils.RetryAnalyzer$RetryListener"/>
    </listeners>

    <test name="User Smoke Tests">
        <classes>
            <class name="com.vinoth.api.tests.users.GetUserTests">
                <methods>
                    <include name="getAllUsers_returns200WithNonEmptyList"/>
                    <include name="getUserById_returnsExpectedUser"/>
                </methods>
            </class>
            <class name="com.vinoth.api.tests.posts.PostCrudTests">
                <methods>
                    <include name="getAllPosts_returns200"/>
                    <include name="getPostById_returnsExpectedPost"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>