<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<!--
    Contract tests are WireMock-backed — run fully offline, no network needed.
    Safe to run in any CI environment without external API access.
-->
<suite name="Contract Suite" verbose="1" parallel="false">

    <listeners>
        <listener class-name="com.vinoth.automation.listeners.AllureListener"/>
        <listener class-name="com.vinoth.automation.listeners.ExtentListener"/>
    </listeners>

    <test name="Contract Tests">
        <groups>
            <run>
                <include name="contract"/>
            </run>
        </groups>
        <classes>
            <class name="com.vinoth.automation.tests.contract.UserContractTests"/>
            <class name="com.vinoth.automation.tests.contract.PostContractTests"/>
        </classes>
    </test>

</suite>